{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist-electron",
        "rootDir": "./electron",
        "module": "commonjs",
        "target": "es6",
        "lib": [
            "es2020",
            "dom"
        ],
        "types": [
            "node",
            "electron"
        ],
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "exactOptionalPropertyTypes": false
    },
    "include": [
        "electron/**/*"
    ]
}