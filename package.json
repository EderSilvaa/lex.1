{
  "name": "lex-juridico",
  "version": "1.0.0",
  "description": "Assistente jurídico inteligente para o sistema PJe",
  "main": "dist-electron/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.electron.json && npm run copy-assets",
    "copy-assets": "node scripts/copy-assets.js",
    "build:watch": "tsc -p tsconfig.electron.json --watch",
    "electron:dev": "concurrently \"npm run build:watch\" \"wait-on dist-electron/main.js && npm run electron:start\"",
    "electron:start": "node scripts/launch-electron.js",
    "electron:build": "npm run build",
    "type-check": "tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint electron/**/*.ts",
    "clean": "rimraf dist-electron",
    "python:setup": "node scripts/download-python-embedded.js",
    "dist:win": "npm run python:setup && npm run electron:build && electron-builder --win --publish never",
    "dist:win:publish": "npm run python:setup && npm run electron:build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.lex.juridico",
    "productName": "LEX Juridico",
    "copyright": "Copyright © 2025 LEX Team",
    "directories": {
      "output": "release",
      "buildResources": "build-assets"
    },
    "files": [
      "dist-electron/**",
      "src/renderer/**",
      "electron/overlay.css",
      "electron/overlay.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/python-embedded",
        "to": "python-embedded",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@nut-tree-fork/**",
      "node_modules/playwright-core/**",
      "node_modules/pdf-parse/**",
      "node_modules/node-pty/**",
      "node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LEX Juridico",
      "installerIcon": "build-assets/icon.ico",
      "uninstallerIcon": "build-assets/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "SEU_USUARIO_GITHUB",
      "repo": "lex-juridico"
    }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/openai": "^3.0.41",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@supabase/supabase-js": "^2.98.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.3.2",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "mammoth": "^1.11.0",
    "marked": "^17.0.4",
    "node-pty": "^1.1.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "playwright-core": "^1.58.1",
    "quill": "^1.3.7",
    "screenshot-desktop": "^1.15.3",
    "telegraf": "^4.16.3",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.27",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^8.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "wait-on": "^9.0.3"
  },
  "keywords": [
    "electron",
    "typescript",
    "pje",
    "ai",
    "legal"
  ],
  "author": "LEX Team",
  "license": "MIT"
}
